<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="OJS-SAST Security Scan Report">
    <title>OJS-SAST Security Report — {{ report.timestamp }}</title>
    <style>
        :root {
            --bg-primary: #f9fafb;
            --bg-secondary: #ffffff;
            --bg-tertiary: #f3f4f6;
            --border: #e5e7eb;
            --text-primary: #111827;
            --text-secondary: #4b5563;
            --text-muted: #6b7280;
            --severity-critical: #dc2626;
            --severity-high: #ea580c;
            --severity-medium: #d97706;
            --severity-low: #3b82f6;
            --severity-info: #6b7280;
            --success: #16a34a;
            --radius: 8px;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: Arial, Helvetica, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            font-size: 15px;
        }
        .container { 
            max-width: 98%; 
            width: 100%;
            margin: 0 auto; 
            padding: 24px; 
        }
        .header {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 32px;
            margin-bottom: 24px;
            box-shadow: var(--shadow);
        }
        .header h1 {
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 12px;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }
        .header-meta { color: var(--text-secondary); font-size: 14px; font-weight: normal; }
        .header-meta span { margin-right: 32px; display: inline-block; margin-bottom: 8px; }
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }
        .summary-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 28px 20px;
            text-align: center;
            box-shadow: var(--shadow);
            transition: all 0.2s ease;
        }
        .summary-card:hover { 
            transform: translateY(-4px); 
            box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.1);
        }
        .summary-card .count {
            font-size: 38px;
            font-weight: bold;
            line-height: 1;
        }
        .summary-card .label {
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            font-weight: bold;
            color: var(--text-secondary);
            margin-top: 10px;
        }
        .sev-critical .count { color: var(--severity-critical); }
        .sev-high .count { color: var(--severity-high); }
        .sev-medium .count { color: var(--severity-medium); }
        .sev-low .count { color: var(--severity-low); }
        .sev-info .count { color: var(--severity-info); }
        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }
        .chart-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
        }
        .chart-card h3 {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 20px;
            color: var(--text-primary);
            border-bottom: 1px solid var(--border);
            padding-bottom: 12px;
        }
        .bar-chart .bar-row {
            display: flex;
            align-items: center;
            margin-bottom: 14px;
        }
        .bar-chart .bar-label {
            width: 110px;
            font-size: 13px;
            font-weight: bold;
            color: var(--text-secondary);
        }
        .bar-chart .bar-track {
            flex: 1;
            height: 22px;
            background: var(--bg-tertiary);
            border-radius: 6px;
            overflow: hidden;
            margin: 0 16px;
        }
        .bar-chart .bar-fill {
            height: 100%;
            border-radius: 4px;
        }
        .bar-chart .bar-value {
            width: 45px;
            text-align: right;
            font-size: 14px;
            font-weight: bold;
            color: var(--text-primary);
        }
        .filters {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            margin-bottom: 32px;
            display: flex;
            gap: 24px;
            align-items: flex-end;
            flex-wrap: wrap;
            box-shadow: var(--shadow);
        }
        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .filters label {
            font-size: 13px;
            font-weight: bold;
            color: var(--text-primary);
        }
        .filters select, .filters input {
            background: var(--bg-secondary);
            border: 1px solid #d1d5db;
            color: var(--text-primary);
            padding: 10px 14px;
            border-radius: 6px;
            font-size: 14px;
            outline: none;
            min-width: 180px;
        }
        .filters input[type="text"] { min-width: 250px; flex-grow: 1; }
        .btn-reset {
            padding: 10px 20px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 13px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-reset:hover { background: #e5e7eb; }
        .filter-count {
            margin-left: auto;
            font-size: 14px;
            font-weight: bold;
            color: var(--text-muted);
            padding-bottom: 12px;
        }
        .findings-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow);
        }
        .findings-table th {
            background: #f8fafc;
            padding: 18px 16px;
            text-align: left;
            font-size: 13px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-secondary);
            cursor: pointer;
            border-bottom: 2px solid var(--border);
        }
        .findings-table th:hover { background: #f1f5f9; }
        .findings-table td {
            padding: 18px 16px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
            vertical-align: middle;
        }
        .findings-table tr:hover td { background: #f8fafc; }
        .findings-table tr { cursor: pointer; }
        .badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
        }
        .badge-CRITICAL { background: #fee2e2; color: var(--severity-critical); border: 1px solid #fca5a5; }
        .badge-HIGH { background: #ffedd5; color: var(--severity-high); border: 1px solid #fdba74; }
        .badge-MEDIUM { background: #fef3c7; color: var(--severity-medium); border: 1px solid #fcd34d; }
        .badge-LOW { background: #dbeafe; color: var(--severity-low); border: 1px solid #93c5fd; }
        .badge-INFO { background: #f3f4f6; color: var(--severity-info); border: 1px solid #d1d5db; }
        .footer {
            text-align: center;
            padding: 40px;
            font-size: 14px;
            color: var(--text-muted);
            border-top: 1px solid var(--border);
            margin-top: 40px;
        }
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(17, 24, 39, 0.6);
            backdrop-filter: blur(4px);
            z-index: 100;
            overflow-y: auto;
            padding: 40px 20px;
        }
        .modal-overlay.active { display: flex; justify-content: center; align-items: flex-start; }
        .modal {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 12px;
            max-width: 1000px;
            width: 100%;
            padding: 40px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border);
        }
        .modal-header h2 { font-size: 24px; font-weight: bold; color: var(--text-primary); }
        .modal-close {
            background: #f3f4f6;
            border: none;
            color: var(--text-secondary);
            font-size: 18px;
            cursor: pointer;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        .modal-close:hover { background: #e5e7eb; color: var(--text-primary); }
        .detail-section h4 { font-size: 13px; color: var(--text-secondary); margin-bottom: 12px; font-weight: bold; text-transform: uppercase; }
        .detail-section p { font-size: 14px; line-height: 1.6; }
        .code-block {
            background: #f8fafc;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 16px;
            overflow-x: auto;
            font-family: Consolas, 'Courier New', monospace;
            font-size: 13px;
            line-height: 1.5;
            white-space: pre;
            color: #0f172a;
        }
        .meta-tags { display: flex; gap: 8px; flex-wrap: wrap; }
        .meta-tag {
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            padding: 4px 12px;
            border-radius: 16px;
            font-size: 12px;
            font-weight: bold;
            color: var(--text-secondary);
        }
        @media (max-width: 1024px) {
            .charts-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>OJS-SAST Security Audit Report</h1>
            <div class="header-meta">
                <span>📅 <strong>Generated:</strong> {{ report.timestamp }}</span>
                <span>📂 <strong>Target:</strong> {{ report.ojs_path }}</span>
                {% if report.ojs_version %}<span>🏷️ <strong>Version:</strong> OJS {{ report.ojs_version }}</span>{% endif %}
                <span>⏱️ <strong>Scan Time:</strong> {{ "%.1f"|format(report.scan_duration_seconds) }}s</span>
                <span>📄 <strong>Files:</strong> {{ report.files_scanned }} scanned</span>
                <span>📏 <strong>Rules:</strong> {{ report.rules_loaded }} active</span>
            </div>
        </div>

        <div class="summary-grid">
            <div class="summary-card sev-critical">
                <div class="count" id="summary-count-CRITICAL">{{ summary.CRITICAL }}</div>
                <div class="label">Critical</div>
            </div>
            <div class="summary-card sev-high">
                <div class="count" id="summary-count-HIGH">{{ summary.HIGH }}</div>
                <div class="label">High</div>
            </div>
            <div class="summary-card sev-medium">
                <div class="count" id="summary-count-MEDIUM">{{ summary.MEDIUM }}</div>
                <div class="label">Medium</div>
            </div>
            <div class="summary-card sev-low">
                <div class="count" id="summary-count-LOW">{{ summary.LOW }}</div>
                <div class="label">Low</div>
            </div>
            <div class="summary-card sev-info">
                <div class="count" id="summary-count-INFO">{{ summary.INFO }}</div>
                <div class="label">Info</div>
            </div>
        </div>

        <div class="charts-row">
            <div class="chart-card">
                <h3>Findings Severity Distribution</h3>
                <div class="bar-chart" id="chart-severity">
                    {% set total = (summary.CRITICAL + summary.HIGH + summary.MEDIUM + summary.LOW + summary.INFO) or 1 %}
                    {% for sev, color in [('CRITICAL', '#dc2626'), ('HIGH', '#ea580c'), ('MEDIUM', '#d97706'), ('LOW', '#3b82f6'), ('INFO', '#6b7280')] %}
                    <div class="bar-row">
                        <span class="bar-label">{{ sev }}</span>
                        <div class="bar-track">
                            <div class="bar-fill" id="bar-fill-sev-{{ sev }}" style="width: {{ (summary[sev] / total * 100)|round(1) }}%; background: {{ color }};"></div>
                        </div>
                        <span class="bar-value" id="bar-val-sev-{{ sev }}" style="color: {{ color }};">{{ summary[sev] }}</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
            <div class="chart-card">
                <h3>Findings by Category</h3>
                <div class="bar-chart" id="chart-category">
                    {% for cat, cat_findings in by_category.items() %}
                    <div class="bar-row">
                        <span class="bar-label">
                            {% if cat == 'config' %}Configuration{% elif cat == 'source_code' %}Source Code{% elif cat == 'uploaded_file' %}Uploaded File{% else %}{{ cat|replace('_', ' ')|title }}{% endif %}
                        </span>
                        <div class="bar-track">
                            <div class="bar-fill" id="bar-fill-cat-{{ cat }}" style="width: {{ (cat_findings|length / total * 100)|round(1) }}%; background: #4b5563;"></div>
                        </div>
                        <span class="bar-value" id="bar-val-cat-{{ cat }}">{{ cat_findings|length }}</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="filters">
            <div class="filter-group">
                <label>Severity</label>
                <select id="filterSeverity" onchange="filterFindings()">
                    <option value="all">All Severities</option>
                    <option value="CRITICAL">Critical</option>
                    <option value="HIGH">High</option>
                    <option value="MEDIUM">Medium</option>
                    <option value="LOW">Low</option>
                    <option value="INFO">Info</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Category</label>
                <select id="filterCategory" onchange="filterFindings()">
                    <option value="all">All Categories</option>
                    <option value="source_code">Source Code</option>
                    <option value="config">Configuration</option>
                    <option value="uploaded_file">Uploaded File</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Rule ID</label>
                <select id="filterRuleID" onchange="filterFindings()">
                    <option value="all">All Rule IDs</option>
                </select>
            </div>
            <div class="filter-group">
                <label>CWE ID</label>
                <select id="filterCWE" onchange="filterFindings()">
                    <option value="all">All CWEs</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Search Keyword</label>
                <input type="text" id="filterSearch" placeholder="Search by name, file..." oninput="filterFindings()">
            </div>
            <button class="btn-reset" onclick="resetFilters()">Reset All</button>
            <span class="filter-count" id="filterCount">Showing {{ findings|length }} findings</span>
        </div>

        <table class="findings-table" id="findingsTable">
            <thead>
                <tr>
                    <th onclick="sortTable(0)">Severity ⇅</th>
                    <th onclick="sortTable(1)">Rule ID ⇅</th>
                    <th onclick="sortTable(2)">Finding Name ⇅</th>
                    <th onclick="sortTable(3)">Category ⇅</th>
                    <th onclick="sortTable(4)">File Path ⇅</th>
                    <th>Line</th>
                    <th>CWE</th>
                </tr>
            </thead>
            <tbody>
                {% for finding in findings %}
                <tr class="finding-row"
                    data-severity="{{ finding.severity }}"
                    data-category="{{ finding.category }}"
                    data-cwe="{{ finding.cwe or 'None' }}"
                    data-rule-id="{{ finding.rule_id }}"
                    data-index="{{ loop.index0 }}"
                    onclick="showDetail({{ loop.index0 }})">
                    <td><span class="badge badge-{{ finding.severity }}">{{ finding.severity }}</span></td>
                    <td style="font-family: Consolas, monospace; font-weight: bold;">{{ finding.rule_id }}</td>
                    <td style="font-weight: bold;">{{ finding.name }}</td>
                    <td>{% if finding.category == 'config' %}Configuration{% elif finding.category == 'source_code' %}Source Code{% elif finding.category == 'uploaded_file' %}Uploaded File{% else %}{{ finding.category|replace('_', ' ')|title }}{% endif %}</td>
                    <td style="font-size: 13px; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{ finding.file_path }}">{{ finding.file_path.split('/')[-1] }}</td>
                    <td style="font-weight: bold;">{{ finding.line_start }}</td>
                    <td>{% if finding.cwe %}<span class="meta-tag">{{ finding.cwe }}</span>{% else %}—{% endif %}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="footer">
            OJS-SAST v{{ report.scanner_version }} • Security Scan Report • {{ report.timestamp }}
        </div>
    </div>

    <div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
        <div class="modal">
            <div class="modal-header">
                <h2 id="modalTitle"></h2>
                <button class="modal-close" onclick="closeModal()">✕</button>
            </div>
            <div id="modalBody"></div>
        </div>
    </div>

    <script>
        const findings = {{ findings | tojson }};
        const sevOrder = {CRITICAL: 0, HIGH: 1, MEDIUM: 2, LOW: 3, INFO: 4};

        document.addEventListener('DOMContentLoaded', () => {
            populateCWEFilter();
            populateRuleIDFilter();
            sortTable(0);
        });

        function populateCWEFilter() {
            const cweSelect = document.getElementById('filterCWE');
            const cwes = [...new Set(findings.map(f => f.cwe).filter(Boolean))].sort();
            cwes.forEach(cwe => {
                const opt = document.createElement('option');
                opt.value = cwe;
                opt.textContent = cwe;
                cweSelect.appendChild(opt);
            });
        }

        function populateRuleIDFilter() {
            const ruleSelect = document.getElementById('filterRuleID');
            const ruleCounts = {};
            
            findings.forEach(f => {
                const rid = f.rule_id;
                if (rid) {
                    ruleCounts[rid] = (ruleCounts[rid] || 0) + 1;
                }
            });

            const sortedRules = Object.keys(ruleCounts).sort();

            sortedRules.forEach(rid => {
                const opt = document.createElement('option');
                opt.value = rid;
                opt.textContent = `${rid} (${ruleCounts[rid]})`;
                ruleSelect.appendChild(opt);
            });
        }

        function filterFindings() {
            const severity = document.getElementById('filterSeverity').value;
            const category = document.getElementById('filterCategory').value;
            const cwe = document.getElementById('filterCWE').value;
            const ruleId = document.getElementById('filterRuleID').value;
            const search = document.getElementById('filterSearch').value.toLowerCase();
            const rows = document.querySelectorAll('.finding-row');
            let visible = 0;
            
            let visibleCounts = {
                severity: { CRITICAL: 0, HIGH: 0, MEDIUM: 0, LOW: 0, INFO: 0 },
                category: {}
            };

            rows.forEach(row => {
                const s = row.dataset.severity;
                const c = row.dataset.category;
                const cw = row.dataset.cwe;
                const rid = row.dataset.ruleId;
                const text = row.textContent.toLowerCase();
                
                const show = (severity === 'all' || s === severity) &&
                             (category === 'all' || c === category) &&
                             (cwe === 'all' || cw === cwe) &&
                             (ruleId === 'all' || rid === ruleId) &&
                             (search === '' || text.includes(search));
                
                row.style.display = show ? '' : 'none';
                if (show) {
                    visible++;
                    if (visibleCounts.severity[s] !== undefined) visibleCounts.severity[s]++;
                    visibleCounts.category[c] = (visibleCounts.category[c] || 0) + 1;
                }
            });

            document.getElementById('filterCount').textContent = `Showing ${visible} of ${findings.length} findings`;
            updateCharts(visibleCounts, visible || 1);
        }

        function updateCharts(counts, totalVisible) {
            for (const sev in counts.severity) {
                const countElem = document.getElementById(`summary-count-${sev}`);
                if (countElem) countElem.textContent = counts.severity[sev];
                
                const barFill = document.getElementById(`bar-fill-sev-${sev}`);
                const barVal = document.getElementById(`bar-val-sev-${sev}`);
                if (barFill && barVal) {
                    const pct = (counts.severity[sev] / totalVisible * 100).toFixed(1);
                    barFill.style.width = `${pct}%`;
                    barVal.textContent = counts.severity[sev];
                }
            }
            
            document.querySelectorAll('[id^="bar-fill-cat-"]').forEach(fillElem => {
                const cat = fillElem.id.replace('bar-fill-cat-', '');
                const valElem = document.getElementById(`bar-val-cat-${cat}`);
                const count = counts.category[cat] || 0;
                const pct = (count / totalVisible * 100).toFixed(1);
                
                fillElem.style.width = `${pct}%`;
                if (valElem) valElem.textContent = count;
            });
        }

        function resetFilters() {
            document.getElementById('filterSeverity').value = 'all';
            document.getElementById('filterCategory').value = 'all';
            document.getElementById('filterRuleID').value = 'all';
            document.getElementById('filterCWE').value = 'all';
            document.getElementById('filterSearch').value = '';
            filterFindings();
        }

        function sortTable(col) {
            const table = document.getElementById('findingsTable');
            const tbody = table.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.sort((a, b) => {
                let av = a.cells[col].innerText.trim();
                let bv = b.cells[col].innerText.trim();
                
                if (col === 0) {
                    return (sevOrder[av] ?? 5) - (sevOrder[bv] ?? 5);
                }
                if (col === 5) {
                    return parseInt(av) - parseInt(bv);
                }
                return av.localeCompare(bv);
            });

            const currentDir = table.dataset.sortDir || 'asc';
            const currentCol = table.dataset.sortCol;

            if (currentCol === String(col)) {
                if (currentDir === 'asc') {
                    rows.reverse();
                    table.dataset.sortDir = 'desc';
                } else {
                    table.dataset.sortDir = 'asc';
                }
            } else {
                table.dataset.sortCol = String(col);
                table.dataset.sortDir = 'asc';
            }

            rows.forEach(r => tbody.appendChild(r));
        }

        function showDetail(idx) {
            const f = findings[idx];
            document.getElementById('modalTitle').textContent = f.name;

            let html = `
                <div class="detail-section">
                    <span class="badge badge-${f.severity}">${f.severity}</span>
                    <div class="meta-tags" style="margin-top: 16px;">
                        ${f.cwe ? `<span class="meta-tag">${f.cwe}</span>` : ''}
                        ${f.owasp ? `<span class="meta-tag">OWASP ${f.owasp}</span>` : ''}
                        <span class="meta-tag">${f.category.replace('_', ' ').toUpperCase()}</span>
                        <span class="meta-tag" style="font-family: Consolas, monospace;">${f.rule_id}</span>
                    </div>
                </div>
                <div class="detail-section">
                    <h4>Description</h4>
                    <p>${f.description}</p>
                </div>
                <div class="detail-section">
                    <h4>Location</h4>
                    <p style="font-family: Consolas, monospace; font-size: 14px; background: #f8fafc; padding: 12px; border-radius: 6px; border: 1px solid var(--border); display: block; word-break: break-all;">${f.file_path} : <strong>Line ${f.line_start}</strong></p>
                </div>`;

            if (f.taint_path) {
                let steps = f.taint_path.intermediate_steps || [];
                let pathHtml = `<ul style="list-style-type: none; padding-left: 0; font-family: Consolas, monospace; font-size: 13px; margin: 0;">`;
                
                pathHtml += `<li style="margin-bottom: 8px;">🟢 <strong style="color: var(--text-primary);">Source:</strong> ${escapeHtml(f.taint_path.source)} <br><span style="color: #64748b; margin-left: 24px; font-size: 12px;">${escapeHtml(f.taint_path.source_location)}</span></li>`;
                
                if (steps.length > 0) {
                    if (steps.length > 3) {
                        pathHtml += `<li style="margin-bottom: 8px; padding-left: 24px;">`;
                        pathHtml += `<button onclick="toggleTaintSteps(this)" style="background: none; border: 1px dashed #cbd5e1; padding: 4px 8px; color: #64748b; border-radius: 4px; cursor: pointer; font-size: 12px; margin-bottom: 4px; font-family: inherit;">+ Show ${steps.length} intermediate steps</button>`;
                        pathHtml += `<ul class="taint-steps-list" style="display: none; list-style-type: none; padding-left: 0; margin-top: 8px; margin-bottom: 0;">`;
                        steps.forEach(step => {
                            pathHtml += `<li style="margin-bottom: 8px; color: #64748b;">↓ ${escapeHtml(step)}</li>`;
                        });
                        pathHtml += `</ul></li>`;
                    } else {
                        steps.forEach(step => {
                            pathHtml += `<li style="margin-bottom: 8px; padding-left: 24px; color: #64748b;">↓ ${escapeHtml(step)}</li>`;
                        });
                    }
                }
                
                let sinkColor = f.taint_path.sanitized ? "var(--warning)" : "var(--danger)";
                let sinkIcon = f.taint_path.sanitized ? "🟡" : "🔴";
                
                pathHtml += `<li style="margin-top: 4px;">${sinkIcon} <strong style="color: ${sinkColor};">Sink:</strong> ${escapeHtml(f.taint_path.sink)} <br><span style="color: #64748b; margin-left: 24px; font-size: 12px;">${escapeHtml(f.taint_path.sink_location)}</span></li>`;
                pathHtml += `</ul>`;

                html += `
                <div class="detail-section">
                    <h4>Taint Data Flow</h4>
                    <div style="background: #f8fafc; padding: 12px; border-radius: 6px; border: 1px solid var(--border); overflow-x: auto;">
                        ${pathHtml}
                    </div>
                </div>`;
            }

            if (f.code_snippet) {
                html += `
                <div class="detail-section">
                    <h4>Code Snippet</h4>
                    <div class="code-block">${escapeHtml(f.code_snippet)}</div>
                </div>`;
            }

            if (f.remediation) {
                html += `
                <div class="detail-section">
                    <h4>Remediation Guidance</h4>
                    <p style="background: #ecfdf5; padding: 16px; border-radius: 6px; border-left: 4px solid var(--success);">${escapeHtml(f.remediation)}</p>
                </div>`;
            }

            document.getElementById('modalBody').innerHTML = html;
            document.getElementById('modalOverlay').classList.add('active');
        }

        function closeModal() {
            document.getElementById('modalOverlay').classList.remove('active');
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function toggleTaintSteps(btn) {
            const ul = btn.nextElementSibling;
            if (ul.style.display === 'none') {
                ul.style.display = 'block';
                btn.textContent = '- Hide intermediate steps';
            } else {
                ul.style.display = 'none';
                btn.textContent = '+ Show ' + ul.children.length + ' intermediate steps';
            }
        }

        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
    </script>
</body>
</html>